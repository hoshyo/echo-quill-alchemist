# Echo-Quill Alchemist — copy to .env and fill in keys.
#
# Pick ONE provider. The backend auto-detects: if LLM_PROVIDER is unset,
# it uses anthropic when ANTHROPIC_API_KEY is present, otherwise openai.

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Optional override ---
# LLM_PROVIDER=anthropic   # or openai

# --- Server ---
HOST=0.0.0.0
PORT=8000
